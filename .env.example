# ── Social Platforms (used by n8n workflow 19) ────────────────────────────────
# X / Twitter — OAuth 2.0 credentials set in n8n, not here
# LinkedIn — OAuth 2.0 credentials set in n8n, not here
INSTAGRAM_ACCOUNT_ID=          # Instagram Business Account ID (from Meta Business Suite)
INSTAGRAM_ACCESS_TOKEN=        # Long-lived Meta Graph API token — same app as Facebook
LINKEDIN_PERSON_URN=           # urn:li:person:XXXXXXXX (from LinkedIn developer portal)
TIKTOK_ACCESS_TOKEN=           # TikTok Content Posting API token (requires app approval)
FACEBOOK_PAGE_ID=              # Facebook Page ID (from Meta Business Suite → Page Settings)
FACEBOOK_PAGE_ACCESS_TOKEN=    # Page access token — same Meta app as Instagram, different token scope
HCTI_USER_ID=                  # htmlcsstoimage.com user ID (for Instagram card images)
HCTI_API_KEY=                  # htmlcsstoimage.com API key
# YouTube OAuth2 credentials are set in n8n credential manager, not here
