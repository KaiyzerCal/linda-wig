# ================================================================
# Respondfall — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to source control.
# ================================================================

# ----------------------------------------------------------------
# Supabase — frontend (VITE_ prefix = safe to expose in browser)
# ----------------------------------------------------------------
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ----------------------------------------------------------------
# Supabase — edge functions only (never in frontend)
# ----------------------------------------------------------------
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# ----------------------------------------------------------------
# Twilio — edge functions only (never in frontend)
# ----------------------------------------------------------------
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# ----------------------------------------------------------------
# Anthropic — edge functions only (never in frontend)
# ----------------------------------------------------------------
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ----------------------------------------------------------------
# App
# ----------------------------------------------------------------
VITE_APP_URL=http://localhost:5173
