# ================================================================
# Respondfall — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to source control.
#
# NOTE: Respondfall uses its OWN dedicated Supabase project.
#       Do not share these values with any other app (e.g. Linda).
# ================================================================

# ----------------------------------------------------------------
# Supabase — frontend (VITE_ prefix = safe to expose in browser)
# ----------------------------------------------------------------
VITE_SUPABASE_URL=https://your-respondfall-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ----------------------------------------------------------------
# n8n — webhook base URL (VITE_ prefix = safe to expose in browser)
# Set to your n8n Cloud instance base, e.g.:
#   https://your-instance.app.n8n.cloud/webhook
# ----------------------------------------------------------------
VITE_N8N_BASE_URL=https://your-instance.app.n8n.cloud/webhook

# ----------------------------------------------------------------
# App
# ----------------------------------------------------------------
VITE_APP_URL=http://localhost:5173

# ================================================================
# The variables below are for n8n ONLY.
# Add them in n8n → Settings → Variables (or via n8n Cloud env).
# NEVER put them in this .env or expose them to the browser.
# All use the RESPONDFALL_ prefix to isolate from other workflows.
# ================================================================

# Respondfall Supabase (server-side — separate project from Linda)
# RESPONDFALL_SUPABASE_URL=https://your-respondfall-project.supabase.co
# RESPONDFALL_SUPABASE_SERVICE_KEY=your_service_role_key_here

# Twilio (server-side)
# RESPONDFALL_TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
# RESPONDFALL_TWILIO_AUTH_TOKEN=your_twilio_auth_token_here

# Anthropic (server-side)
# RESPONDFALL_ANTHROPIC_API_KEY=your_anthropic_api_key_here
